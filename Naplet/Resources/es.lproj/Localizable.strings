"legal.lastUpdate" = "Última actualización: Enero 2026";

// Privacy Policy Sections
"legal.privacy.section1.title" = "1. Información que Recopilamos";
"legal.privacy.section1.content" = "Naplet recopila la siguiente información:\n• Datos del perfil (nombre, email)\n• Datos del bebé (nombre, fecha de nacimiento)\n• Registros de sueño, alimentación y pañales\n• Datos de uso de la aplicación";

"legal.privacy.section2.title" = "2. Cómo Usamos tu Información";
"legal.privacy.section2.content" = "Usamos tus datos para:\n• Proporcionar predicciones de sueño personalizadas\n• Sincronizar datos entre cuidadores\n• Mejorar nuestros servicios\n• Enviar notificaciones relevantes";

"legal.privacy.section3.title" = "3. Compartir Datos";
"legal.privacy.section3.content" = "Tus datos solo se comparten con:\n• Cuidadores que invites\n• Proveedores de servicios esenciales (Supabase, RevenueCat)\n\nNunca vendemos tus datos a terceros.";

"legal.privacy.section4.title" = "4. Seguridad";
"legal.privacy.section4.content" = "Protegemos tus datos con:\n• Cifrado en tránsito y en reposo\n• Autenticación segura\n• Políticas de acceso restringidas";

"legal.privacy.section5.title" = "5. Tus Derechos";
"legal.privacy.section5.content" = "Puedes:\n• Acceder a tus datos en cualquier momento\n• Solicitar la eliminación de tu cuenta\n• Exportar tus datos\n• Revocar permisos de cuidadores";

"legal.privacy.section6.title" = "6. Contacto";
"legal.privacy.section6.content" = "Para preguntas sobre privacidad:\ncontacto@naplet.app";

"legal.privacy.section7.title" = "7. Chat IA y Compartir Datos con Terceros";
"legal.privacy.section7.content" = "Nuestro recurso de Chat IA utiliza la API de OpenAI para proporcionar orientacion personalizada sobre el sueno del bebe. Cuando usas el Chat IA, los siguientes datos pueden enviarse a OpenAI:\n\n• Nombre y edad de tu bebe\n• Registros y patrones de sueno\n• Tus mensajes y preguntas en el chat\n\nEstos datos se envian solo cuando usas activamente el recurso de Chat IA y solo despues de que hayas otorgado consentimiento explicito.\n\nOpenAI procesa estos datos exclusivamente para generar respuestas y no retiene datos personales despues del procesamiento, de acuerdo con la politica de uso de datos de OpenAI.\n\nPuedes revocar tu consentimiento en cualquier momento en Configuracion > Compartir Datos IA. Revocar el consentimiento deshabilitara el recurso de Chat IA.\n\nGarantizamos que OpenAI, como nuestro procesador de datos externo, proporciona proteccion equivalente de tus datos segun lo descrito en esta politica de privacidad.";

// Terms of Service Sections
"legal.terms.section1.title" = "1. Aceptación de los Términos";
"legal.terms.section1.content" = "Al usar Naplet, aceptas estos términos. Si no estás de acuerdo, no uses la aplicación.";

"legal.terms.section2.title" = "2. Uso del Servicio";
"legal.terms.section2.content" = "Naplet es una herramienta para ayudar a rastrear el sueño del bebé. La app no reemplaza el consejo médico profesional.\n\nEres responsable de:\n• Mantener tus credenciales seguras\n• Información precisa sobre tu bebé\n• Uso adecuado de la aplicación";

"legal.terms.section3.title" = "3. Suscripción Premium";
"legal.terms.section3.content" = "• El período de prueba gratuito es de 7 días\n• La facturación es anual después del período de prueba\n• Puedes cancelar en cualquier momento\n• Los reembolsos siguen las políticas de App Store";

"legal.terms.section4.title" = "4. Limitaciones";
"legal.terms.section4.content" = "Naplet se proporciona \"tal cual\". No garantizamos:\n• Disponibilidad ininterrumpida\n• Precisión absoluta de las predicciones\n• Resultados específicos";

"legal.terms.section5.title" = "5. Propiedad Intelectual";
