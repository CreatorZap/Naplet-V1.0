// Privacy Policy Sections
"legal.privacy.section1.title" = "1. Information We Collect";
"legal.privacy.section1.content" = "Naplet collects the following information:\n• Profile data (name, email)\n• Baby data (name, birth date)\n• Sleep, feeding, and diaper records\n• App usage data";

"legal.privacy.section2.title" = "2. How We Use Your Information";
"legal.privacy.section2.content" = "We use your data to:\n• Provide personalized sleep predictions\n• Sync data between caregivers\n• Improve our services\n• Send relevant notifications";

"legal.privacy.section3.title" = "3. Data Sharing";
"legal.privacy.section3.content" = "Your data is only shared with:\n• Caregivers you invite\n• Essential service providers (Supabase, RevenueCat)\n\nWe never sell your data to third parties.";

"legal.privacy.section4.title" = "4. Security";
"legal.privacy.section4.content" = "We protect your data with:\n• Encryption in transit and at rest\n• Secure authentication\n• Restricted access policies";

"legal.privacy.section5.title" = "5. Your Rights";
"legal.privacy.section5.content" = "You can:\n• Access your data at any time\n• Request account deletion\n• Export your data\n• Revoke caregiver permissions";

"legal.privacy.section6.title" = "6. Contact";
"legal.privacy.section6.content" = "For privacy questions:\ncontact@naplet.app";

"legal.privacy.section7.title" = "7. AI Chat & Third-Party Data Sharing";
"legal.privacy.section7.content" = "Our AI Chat feature uses OpenAI's API to provide personalized baby sleep guidance. When you use the AI Chat, the following data may be sent to OpenAI:\n\n• Your baby's name and age\n• Sleep records and patterns\n• Your chat messages and questions\n\nThis data is sent only when you actively use the AI Chat feature and only after you have granted explicit consent.\n\nOpenAI processes this data solely to generate responses and does not retain personal data after processing, in accordance with OpenAI's data usage policy.\n\nYou can revoke your consent at any time in Settings > AI Data Sharing. Revoking consent will disable the AI Chat feature.\n\nWe ensure that OpenAI, as our third-party data processor, provides equal protection of your data as described in this privacy policy.";

// Terms of Service Sections
"legal.terms.section1.title" = "1. Acceptance of Terms";
"legal.terms.section1.content" = "By using Naplet, you agree to these terms. If you disagree, do not use the app.";

"legal.terms.section2.title" = "2. Use of Service";
"legal.terms.section2.content" = "Naplet is a tool to help track baby sleep. The app does not replace professional medical advice.\n\nYou are responsible for:\n• Keeping your credentials secure\n• Accurate information about your baby\n• Proper use of the application";

"legal.terms.section3.title" = "3. Premium Subscription";
"legal.terms.section3.content" = "• Free trial period is 7 days\n• Billing is annual after the trial period\n• You can cancel at any time\n• Refunds follow App Store policies";

"legal.terms.section4.title" = "4. Limitations";
"legal.terms.section4.content" = "Naplet is provided \"as is\". We do not guarantee:\n• Uninterrupted availability\n• Absolute accuracy of predictions\n• Specific results";

