"legal.terms.title" = "Termos de Serviço";
"legal.lastUpdate" = "Última atualização: Janeiro de 2026";

// Privacy Policy Sections
"legal.privacy.section1.title" = "1. Informações que Coletamos";
"legal.privacy.section1.content" = "O Naplet coleta as seguintes informações:\n• Dados do perfil (nome, email)\n• Dados do bebê (nome, data de nascimento)\n• Registros de sono, alimentação e fraldas\n• Dados de uso do aplicativo";

"legal.privacy.section2.title" = "2. Como Usamos suas Informações";
"legal.privacy.section2.content" = "Utilizamos seus dados para:\n• Fornecer previsões de sono personalizadas\n• Sincronizar dados entre cuidadores\n• Melhorar nossos serviços\n• Enviar notificações relevantes";

"legal.privacy.section3.title" = "3. Compartilhamento de Dados";
"legal.privacy.section3.content" = "Seus dados são compartilhados apenas com:\n• Cuidadores que você convidar\n• Provedores de serviço essenciais (Supabase, RevenueCat)\n\nNunca vendemos seus dados a terceiros.";

"legal.privacy.section4.title" = "4. Segurança";
"legal.privacy.section4.content" = "Protegemos seus dados com:\n• Criptografia em trânsito e em repouso\n• Autenticação segura\n• Políticas de acesso restritas";

"legal.privacy.section5.title" = "5. Seus Direitos";
"legal.privacy.section5.content" = "Você pode:\n• Acessar seus dados a qualquer momento\n• Solicitar exclusão da sua conta\n• Exportar seus dados\n• Revogar permissões de cuidadores";

"legal.privacy.section6.title" = "6. Contato";
"legal.privacy.section6.content" = "Para questões sobre privacidade:\ncontato@naplet.app";

"legal.privacy.section7.title" = "7. Chat IA e Compartilhamento de Dados com Terceiros";
"legal.privacy.section7.content" = "Nosso recurso de Chat IA utiliza a API da OpenAI para fornecer orientacoes personalizadas sobre o sono do bebe. Quando voce usa o Chat IA, os seguintes dados podem ser enviados a OpenAI:\n\n• Nome e idade do seu bebe\n• Registros e padroes de sono\n• Suas mensagens e perguntas no chat\n\nEstes dados sao enviados somente quando voce usa ativamente o recurso de Chat IA e somente apos voce ter concedido consentimento explicito.\n\nA OpenAI processa esses dados exclusivamente para gerar respostas e nao retem dados pessoais apos o processamento, de acordo com a politica de uso de dados da OpenAI.\n\nVoce pode revogar seu consentimento a qualquer momento em Configuracoes > Compartilhamento de Dados IA. Revogar o consentimento desabilitara o recurso de Chat IA.\n\nGarantimos que a OpenAI, como nosso processador de dados terceirizado, fornece protecao equivalente dos seus dados conforme descrito nesta politica de privacidade.";

// Terms of Service Sections
"legal.terms.section1.title" = "1. Aceitação dos Termos";
"legal.terms.section1.content" = "Ao usar o Naplet, você concorda com estes termos. Se não concordar, não use o aplicativo.";

"legal.terms.section2.title" = "2. Uso do Serviço";
"legal.terms.section2.content" = "O Naplet é uma ferramenta de auxílio para acompanhamento do sono de bebês. O app não substitui orientação médica profissional.\n\nVocê é responsável por:\n• Manter suas credenciais seguras\n• Informações precisas sobre seu bebê\n• Uso adequado do aplicativo";

"legal.terms.section3.title" = "3. Assinatura Premium";
"legal.terms.section3.content" = "• O período de teste gratuito é de 7 dias\n• A cobrança é anual após o período de teste\n• Você pode cancelar a qualquer momento\n• Reembolsos seguem as políticas da App Store";

"legal.terms.section4.title" = "4. Limitações";
"legal.terms.section4.content" = "O Naplet é fornecido \"como está\". Não garantimos:\n• Disponibilidade ininterrupta\n• Precisão absoluta das previsões\n• Resultados específicos";

"legal.terms.section5.title" = "5. Propriedade Intelectual";
"legal.terms.section5.content" = "Todo o conteúdo do Naplet (design, código, marca) é propriedade de Edy Souza.";

